#!/usr/bin/env bash
#USAGE complete "Generate an Apple-style segmented random password."
#USAGE arg "[segments]" "Number of hyphen-separated segments (default: 3)."

set -euo pipefail

# --- config --------------------------------

# Number of hyphen-separated segments (default: 3).
segments="${1:-3}"

# --- generate ------------------------------

result=()
for ((i = 1; i <= segments; i++)); do
    result+=("$(openssl rand -base64 6 | tr -d '=/+')")
done

IFS='-'
echo "${result[*]}"
