#!/usr/bin/env bash
#USAGE complete "Install Homebrew and Brewfile packages"
#MISE description="Install Homebrew and Brewfile packages"
#MISE hide=true
set -euo pipefail

# shellcheck source=lib/dotfiles/hostname.sh
source "${DOTFILES_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}}/lib/dotfiles/hostname.sh"

# --- install ---------------------------

echo ""
echo "📦 Installing Homebrew..."

if command -v brew &>/dev/null; then
    echo "⏭️ Homebrew already installed, skipping"
else
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
    echo "✔ Done."
fi

echo ""
echo "📦 Installing Brewfile packages..."
brew bundle install
echo "✔ Done."

# Machine-specific Brewfile sidecar
brewfile_dir="$(dirname "${HOMEBREW_BUNDLE_FILE:-$DOTFILES_DIR/brew/Brewfile}")"
machine="${DOTFILES_MACHINE:-$(normalize_hostname "$(get_hostname)")}"
machine_brewfile="${brewfile_dir}/Brewfile.${machine}"
if [[ -f "$machine_brewfile" ]]; then
    echo ""
    echo "📦 Installing machine-specific Brewfile packages (${machine})..."
    brew bundle install --file="$machine_brewfile"
    echo "✔ Done."
fi

echo ""
echo "🎉 Homebrew setup complete"
