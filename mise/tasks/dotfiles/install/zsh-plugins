#!/usr/bin/env bash
#USAGE complete "Clone zsh plugins to XDG_DATA_HOME"
#MISE description="Clone zsh plugins to XDG_DATA_HOME"
#MISE hide=true
set -euo pipefail

# shellcheck source=../../../../lib/dotfiles/zsh-plugins.sh
. "$DOTFILES_DIR/lib/dotfiles/zsh-plugins.sh"

echo ""
echo "⚙️ Configuring..."
echo "→ ZSH_PLUGINS_DIR=$ZSH_PLUGINS_DIR"

# --- install ---------------------------

mkdir -p "$ZSH_PLUGINS_DIR"

echo ""
echo "📦 Cloning zsh plugins..."

failed=0
for pair in "${dotfiles_zsh_plugins[@]}"; do
    name="${pair%%:*}"
    url="${pair#*:}"
    dest="$ZSH_PLUGINS_DIR/$name"

    if [[ -d "$dest" ]]; then
        echo "⏭️ $name already exists, skipping"
        continue
    fi

    if git clone --depth 1 "$url" "$dest"; then
        echo "✔ $name installed"
    else
        echo "🛑 Error: Failed to clone $name" >&2
        failed=$((failed + 1))
    fi
done

if [[ "$failed" -gt 0 ]]; then
    echo ""
    echo "🛑 Error: $failed plugin(s) failed" >&2
    exit 1
fi

echo ""
echo "🎉 All zsh plugins installed"
