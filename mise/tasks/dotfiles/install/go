#!/usr/bin/env bash
#USAGE complete "Configure Go environment variables via go env -w."
#MISE description="Configure Go environment variables via go env -w."
#MISE hide=true
set -euo pipefail

# shellcheck source=../../../../lib/dotfiles/go.sh
. "$DOTFILES_DIR/lib/dotfiles/go.sh"

# --- install ----------------------------

if ! command -v go &>/dev/null; then
    echo "⏭️ go not found on PATH, skipping"
    exit 0
fi

echo ""
echo "⚙️ Configuring Go environment..."
echo "→ GOPATH=$dotfiles_gopath"
echo "→ GOMODCACHE=$dotfiles_gomodcache"
echo "→ GOCACHE=$dotfiles_gocache"

# Ensure the directory for $GOENV exists before go env -w writes to it.
mkdir -p "$(dirname "$GOENV")"

go env -w \
    GOPATH="$dotfiles_gopath" \
    GOMODCACHE="$dotfiles_gomodcache" \
    GOCACHE="$dotfiles_gocache"

echo "✅ Done."
echo ""
echo "🎉 Go environment configured"
