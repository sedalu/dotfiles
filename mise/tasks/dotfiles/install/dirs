#!/usr/bin/env bash
#USAGE complete "Create required XDG directories"
#MISE description="Create required XDG directories"
#MISE hide=true
set -euo pipefail

# shellcheck source=../../../../lib/dotfiles/dirs.sh
. "$DOTFILES_DIR/lib/dotfiles/dirs.sh"

# --- install ---------------------------

echo ""
echo "📁 Creating XDG directories..."

for dir in "${dotfiles_dirs[@]}"; do
    mkdir -p "$dir"
done
echo "✔ Done."

echo ""
echo "🎉 All XDG directories created"
