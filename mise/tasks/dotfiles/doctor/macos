#!/usr/bin/env bash
#USAGE complete "Check macOS defaults match tracked settings"
#MISE description="Check macOS defaults match tracked settings"
#MISE hide=true
set -euo pipefail

if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "⏭️  Not macOS, skipping"
    exit 0
fi

# shellcheck source=../../../../../lib/dotfiles/macos.sh
source "$DOTFILES_DIR/lib/dotfiles/macos.sh"

_dw_domains=() _dw_keys=() _dw_types=() _dw_values=()

while IFS= read -r file; do
    macos_parse_defaults "$file"
done < <(macos_settings_files)

fail=0

for i in "${!_dw_domains[@]}"; do
    domain="${_dw_domains[$i]}"
    key="${_dw_keys[$i]}"
    type="${_dw_types[$i]}"
    value="${_dw_values[$i]}"

    current="$(defaults read "$domain" "$key" 2>/dev/null)" || {
        echo "❌ $domain $key — not set (expected: $value)"
        ((fail++)) || true
        continue
    }

    if macos_values_match "$type" "$value" "$current"; then
        echo "✅ $domain $key = $current"
    else
        echo "❌ $domain $key = $current (expected: $value)"
        ((fail++)) || true
    fi
done

echo ""
if ((fail > 0)); then
    echo "❌ $fail setting(s) out of sync — run 'mise run dotfiles:install:macos'"
    exit 1
fi
echo "✅ All macOS settings correct"
