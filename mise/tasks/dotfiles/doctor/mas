#!/usr/bin/env bash
#USAGE complete "Check mas and App Store sign-in status"
#MISE description="Check mas and App Store sign-in status"
#MISE hide=true

set -euo pipefail

[[ "${DOTFILES_OS:-}" != "darwin" ]] && exit 0

# --- doctor -----------------------------

echo ""
echo "🩺 Checking mas..."

failed=0

if ! command -v mas > /dev/null 2>&1; then
    echo "🛑 Error: mas is not installed" >&2
    failed=$((failed + 1))
fi

if ! mas account > /dev/null 2>&1; then
    echo "🛑 Error: not signed into the App Store (open App Store and sign in)" >&2
    failed=$((failed + 1))
fi

if [[ "${failed}" -gt 0 ]]; then
    echo ""
    echo "🛑 ${failed} check(s) failed" >&2
    exit 1
fi

echo ""
echo "✔ mas ok"
