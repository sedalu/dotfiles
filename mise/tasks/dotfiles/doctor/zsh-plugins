#!/usr/bin/env bash
#USAGE complete "Check zsh plugins are installed (soft warning)"
#MISE description="Check zsh plugins are installed (soft warning)"
#MISE depends=["dotfiles:doctor:dirs"]
#MISE hide=true
set -euo pipefail

# shellcheck source=../../../../lib/dotfiles/zsh-plugins.sh
. "$DOTFILES_DIR/lib/dotfiles/zsh-plugins.sh"

missing=0
for pair in "${dotfiles_zsh_plugins[@]}"; do
    plugin="${pair%%:*}"
    if [[ -d "$ZSH_PLUGINS_DIR/$plugin" ]]; then
        echo "✅ $plugin"
    else
        echo "⚠️ $plugin not found"
        ((missing++)) || true
    fi
done

if ((missing > 0)); then
    echo ""
    echo "⚠️ $missing plugin(s) missing — run mise run dotfiles:install:zsh-plugins"
fi

exit 0
