#!/usr/bin/env bash
#USAGE complete "Check dotfiles bare repo is configured correctly"
#MISE description="Check dotfiles bare repo is configured correctly"
#MISE depends=[dotfiles:doctor:tools]
#MISE hide=true
set -euo pipefail

fail=0

if [[ ! -d "$DOTFILES_GIT" ]]; then
    echo "❌ $DOTFILES_GIT does not exist"
    ((fail++)) || true
else
    echo "✅ $DOTFILES_GIT exists"

    worktree="$(git --git-dir="$DOTFILES_GIT" config core.worktree 2>/dev/null)" || worktree=""
    if [[ "$worktree" == "$DOTFILES_DIR" ]]; then
        echo "✅ core.worktree = $DOTFILES_DIR"
    else
        echo "❌ core.worktree = '$worktree' (expected $DOTFILES_DIR)"
        ((fail++)) || true
    fi

    git_file="$DOTFILES_DIR/.git"
    if [[ ! -f "$git_file" ]]; then
        echo "❌ $git_file does not exist or is not a file"
        ((fail++)) || true
    else
        git_file_content="$(cat "$git_file")"
        expected="gitdir: $DOTFILES_GIT"
        if [[ "$git_file_content" == "$expected" ]]; then
            echo "✅ $git_file → $DOTFILES_GIT"
        else
            echo "❌ $git_file contains '$git_file_content' (expected '$expected')"
            ((fail++)) || true
        fi
    fi
fi

if ((fail > 0)); then
    echo ""
    echo "❌ Repo check failed"
    exit 1
fi
echo ""
echo "✅ Dotfiles repo configured correctly"
