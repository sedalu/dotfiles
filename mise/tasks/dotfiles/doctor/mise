#!/usr/bin/env bash
#USAGE complete "Run mise doctor (soft warning)"
#MISE description="Run mise doctor (soft warning)"
#MISE depends=[dotfiles:doctor:tools]
#MISE hide=true
set -euo pipefail

if mise doctor 2>&1; then
    echo "✅ mise doctor passed"
else
    echo "⚠️ mise doctor reported issues (non-fatal)"
fi

exit 0
