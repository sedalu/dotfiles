#!/usr/bin/env bash
#USAGE complete "Scan macOS settings and save new/changed values"
#MISE description="Scan macOS settings and save new/changed values"
set -euo pipefail

if [[ "$(uname -s)" != "Darwin" ]]; then
    echo "⏭️  Not macOS, skipping"
    exit 0
fi

DOTFILES_DIR="${DOTFILES_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}}"

# shellcheck source=../../../../lib/dotfiles/hostname.sh
source "$DOTFILES_DIR/lib/dotfiles/hostname.sh"

machine="${DOTFILES_MACHINE:-$(normalize_hostname "$(get_hostname)")}"
global_file="$DOTFILES_DIR/macos/settings.sh"
machine_file="$DOTFILES_DIR/macos/settings.${machine}.sh"

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles/macos"
state_current="$state_dir/state.current.txt"
state_previous="$state_dir/state.previous.txt"
changes_file="$state_dir/changes.tmp"
mkdir -p "$state_dir"

# ---------------------------------------------------------------------------
# Awk flattener: transforms `defaults read` nested plist into flat TSV
# Output: domain\tkey\tvalue (one line per scalar key)
# Maps "Apple Global Domain" → NSGlobalDomain
# ---------------------------------------------------------------------------
_PLIST_FLATTENER='
BEGIN { domain = ""; nested = 0 }

# Domain opening: 4-space indent, name = {
/^    / && / =     \{/ && !/^        / {
    line = $0
    sub(/^    /, "", line)
    sub(/ =.*/, "", line)
    gsub(/"/, "", line)
    domain = line
    if (domain == "Apple Global Domain") domain = "NSGlobalDomain"
    nested = 0
    next
}

# Domain closing: 4-space indent };
/^    \};/ {
    domain = ""
    nested = 0
    next
}

# Skip if no domain set
domain == "" { next }

# 12+ space indent: inside nested structure, skip
/^            / { next }

# 8-space indent lines: domain-level keys
/^        / {
    # Nested structure closing
    if (/^        \};/ || /^        \);/) {
        if (nested > 0) nested--
        next
    }

    # Skip if inside nested structure
    if (nested > 0) next

    # Nested structure opening (dict or array)
    if (/\{[[:space:]]*$/ || /\([[:space:]]*$/) {
        nested++
        next
    }

    # Extract scalar key = value
    line = $0
    sub(/^        /, "", line)
    sub(/;[[:space:]]*$/, "", line)

    idx = index(line, " = ")
    if (idx == 0) next

    key = substr(line, 1, idx - 1)
    val = substr(line, idx + 3)

    # Strip quotes from key
    gsub(/"/, "", key)

    # Skip binary data
    if (val ~ /^</) next
    if (val ~ /^\{length = [0-9]+, bytes = 0x/) next

    # Strip surrounding quotes from value
    if (substr(val, 1, 1) == "\"" && substr(val, length(val), 1) == "\"") {
        val = substr(val, 2, length(val) - 2)
    }

    printf "%s\t%s\t%s\n", domain, key, val
}
'

# ---------------------------------------------------------------------------
# Awk diff engine: single pass over previous + current state files
# Output: TYPE<US>domain<US>key<US>old_value<US>new_value  (US = Unit Separator)
# Uses Unit Separator (0x1f) so bash read preserves empty fields
# Filters out changes where BOTH old and new values are timestamps
# ---------------------------------------------------------------------------
_DIFF_ENGINE='
BEGIN { FS = "\t"; us = sprintf("%c", 31) }

# First file: previous state
NR == FNR {
    prev[$1, $2] = $3
    seen[$1, $2] = 1
    next
}

# Second file: current state
{
    pk = $1 SUBSEP $2
    if (pk in prev) {
        if ($3 != prev[pk]) {
            # Noise filters: skip when BOTH old and new match a transient pattern
            dp = "^[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9] [0-9][0-9]:[0-9][0-9]:[0-9][0-9]"
            if (prev[pk] ~ dp && $3 ~ dp) { delete seen[pk]; next }
            # ISO 8601 with T separator
            iso = "^[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]T[0-9][0-9]:[0-9][0-9]:[0-9][0-9]"
            if (prev[pk] ~ iso && $3 ~ iso) { delete seen[pk]; next }
            # Unix/CoreFoundation epoch floats (9+ digit timestamps)
            ep = "^[0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9][0-9]*\\.?[0-9]*$"
            if (prev[pk] ~ ep && $3 ~ ep) { delete seen[pk]; next }
            # HTTP dates (e.g. "Mon, 21 Mar 2026 12:00:00 GMT")
            hd = "^(Mon|Tue|Wed|Thu|Fri|Sat|Sun), [0-9][0-9] (Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec) [0-9][0-9][0-9][0-9] [0-9][0-9]:[0-9][0-9]:[0-9][0-9] GMT$"
            if (prev[pk] ~ hd && $3 ~ hd) { delete seen[pk]; next }
            # US locale dates (e.g. "03/20/2026, 22:57:28.5640")
            usd = "^[0-9][0-9]/[0-9][0-9]/[0-9][0-9][0-9][0-9], [0-9][0-9]:[0-9][0-9]:[0-9][0-9]"
            if (prev[pk] ~ usd && $3 ~ usd) { delete seen[pk]; next }
            printf "CHANGED%s%s%s%s%s%s%s%s\n", us, $1, us, $2, us, prev[pk], us, $3
        }
        delete seen[pk]
    } else {
        printf "NEW%s%s%s%s%s%s%s\n", us, $1, us, $2, us, us, $3
    }
}

END {
    for (pk in seen) {
        split(pk, a, SUBSEP)
        printf "REMOVED%s%s%s%s%s%s%s\n", us, a[1], us, a[2], us, prev[pk], us
    }
}
'

# ---------------------------------------------------------------------------
# Type inference: resolve type at save time via defaults read-type
# ---------------------------------------------------------------------------
_infer_type() {
    local domain="$1" key="$2"
    local raw
    raw="$(defaults read-type "$domain" "$key" 2>/dev/null)" || { echo "string"; return; }
    case "$raw" in
        *boolean*) echo "bool" ;;
        *integer*) echo "int" ;;
        *float*)   echo "float" ;;
        *)         echo "string" ;;
    esac
}

# ---------------------------------------------------------------------------
# Ignore file: domain and domain+key patterns to suppress from scan
# ---------------------------------------------------------------------------
_ignore_file="$DOTFILES_DIR/macos/ignore"
_ignore_domains=()
_ignore_keys=()

if [[ -f "$_ignore_file" ]]; then
    while IFS= read -r line; do
        # Strip comments and whitespace
        line="${line%%#*}"
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" ]] && continue

        if [[ "$line" == *" "* ]]; then
            _ignore_keys+=("$line")
        else
            _ignore_domains+=("$line")
        fi
    done < "$_ignore_file"
fi
_ignore_modified=false

_is_ignored() {
    local domain="$1" key="$2"
    for pat in "${_ignore_domains[@]+"${_ignore_domains[@]}"}"; do
        # shellcheck disable=SC2053
        [[ "$domain" == $pat ]] && return 0
    done
    for pat in "${_ignore_keys[@]+"${_ignore_keys[@]}"}"; do
        local d_pat="${pat%% *}" k_pat="${pat#* }"
        # shellcheck disable=SC2053
        [[ "$domain" == $d_pat && "$key" == $k_pat ]] && return 0
    done
    return 1
}

# ---------------------------------------------------------------------------
# Tracked keys helpers
# ---------------------------------------------------------------------------
_tracked_keys=()
for src in "$global_file" "$machine_file"; do
    [[ -f "$src" ]] || continue
    while IFS= read -r line; do
        if [[ "$line" =~ ^[[:space:]]*\"([^[:space:]]+)[[:space:]]+([^[:space:]]+)[[:space:]] ]]; then
            _tracked_keys+=("${BASH_REMATCH[1]} ${BASH_REMATCH[2]}")
        fi
    done < "$src"
done

_is_tracked() {
    local needle="$1"
    for k in "${_tracked_keys[@]+"${_tracked_keys[@]}"}"; do
        [[ "$k" == "$needle" ]] && return 0
    done
    return 1
}

_get_stored_value() {
    local domain="$1" key="$2" stored=""
    for src in "$global_file" "$machine_file"; do
        [[ -f "$src" ]] || continue
        while IFS= read -r line; do
            if [[ "$line" =~ ^[[:space:]]*\"${domain}[[:space:]]+${key}[[:space:]]+[^[:space:]]+[[:space:]]+(.+)\"[[:space:]]*$ ]]; then
                stored="${BASH_REMATCH[1]}"
                break 2
            fi
        done < "$src"
    done
    echo "$stored"
}

# ---------------------------------------------------------------------------
# Append an entry to a settings file
# ---------------------------------------------------------------------------
_append_entry() {
    local file="$1" entry="$2"
    local line="    \"$entry\""

    if [[ ! -f "$file" ]]; then
        cat > "$file" <<EOF
# macos/settings.${machine}.sh — macOS settings for machine: ${machine}
dotfiles_machine_macos_settings=(
$line
)
EOF
        echo "  📝 Created $file"
        return
    fi

    local domain key
    read -r domain key _ <<< "$entry"
    local tmp
    tmp="$(mktemp)"
    awk -v entry="$line" -v domain="$domain" -v key="$key" '
        /^[[:space:]]*"/ && $0 ~ "\"" domain " " key " " { found=1; print entry; next }
        /^[[:space:]]*\)$/ && !done && !found { print entry; done=1 }
        { print }
    ' "$file" > "$tmp"
    mv "$tmp" "$file"
}

# ---------------------------------------------------------------------------
# Step 1: Snapshot all defaults
# ---------------------------------------------------------------------------
echo ""
echo "📸 Snapshotting all macOS defaults..."

defaults read 2>/dev/null | awk "$_PLIST_FLATTENER" | sort > "$state_current"

echo "   $(wc -l < "$state_current" | tr -d ' ') keys captured"

# ---------------------------------------------------------------------------
# Step 2: First-run guard
# ---------------------------------------------------------------------------
if [[ ! -f "$state_previous" ]]; then
    echo "   (No previous snapshot — diff will run next time)"
    mv "$state_current" "$state_previous"
    exit 0
fi

# ---------------------------------------------------------------------------
# Step 3: Diff against previous snapshot
# ---------------------------------------------------------------------------
echo ""
echo "🔍 Scanning for changes..."
echo "   Machine: $machine"
echo ""

awk -F'\t' "$_DIFF_ENGINE" "$state_previous" "$state_current" > "$changes_file"

if [[ ! -s "$changes_file" ]]; then
    echo "✅ No changes detected."
    mv "$state_current" "$state_previous"
    rm -f "$changes_file"
    exit 0
fi

# ---------------------------------------------------------------------------
# Step 4: Interactive review (fd 3 for data, fd 0 for terminal)
# ---------------------------------------------------------------------------
global_pending=()
machine_pending=()

while IFS=$'\x1f' read -r type domain key old new <&3; do
    # Skip ignored domains/keys
    _is_ignored "$domain" "$key" && continue

    case "$type" in
        NEW)
            echo "  ✦ NEW      $domain $key"
            echo "     now:     $new"
            ;;
        CHANGED)
            if _is_tracked "$domain $key"; then
                stored="$(_get_stored_value "$domain" "$key")"
                echo "  ⚠️  CHANGED  $domain $key"
                echo "     tracked: $stored"
            else
                echo "  ~  CHANGED  $domain $key"
            fi
            echo "     was:     $old"
            echo "     now:     $new"
            ;;
        REMOVED)
            if _is_tracked "$domain $key"; then
                echo "  ✗  REMOVED  $domain $key"
                echo "     was:     $old"
                echo ""
            fi
            continue
            ;;
    esac
    echo ""

    printf "     Save? [g]lobal / [m]achine / [s]kip / [i]gnore: "
    read -r choice
    echo ""

    case "$(echo "$choice" | tr '[:upper:]' '[:lower:]')" in
        g)
            inferred_type="$(_infer_type "$domain" "$key")"
            global_pending+=("$domain $key $inferred_type $new")
            ;;
        m)
            inferred_type="$(_infer_type "$domain" "$key")"
            machine_pending+=("$domain $key $inferred_type $new")
            ;;
        i)
            printf "     Ignore [d]omain (%s) or [k]ey (%s %s)? " "$domain" "$domain" "$key"
            read -r ignore_choice
            case "$(echo "$ignore_choice" | tr '[:upper:]' '[:lower:]')" in
                d)
                    echo "$domain" >> "$_ignore_file"
                    _ignore_domains+=("$domain")
                    echo "     Added domain to ignore: $domain"
                    ;;
                k|*)
                    echo "$domain $key" >> "$_ignore_file"
                    _ignore_keys+=("$domain $key")
                    echo "     Added key to ignore: $domain $key"
                    ;;
            esac
            _ignore_modified=true
            echo ""
            ;;
        *) echo "     Skipped." ; echo "" ;;
    esac
done 3< "$changes_file"

rm -f "$changes_file"

# ---------------------------------------------------------------------------
# Step 5: Write pending entries
# ---------------------------------------------------------------------------
total=$(( ${#global_pending[@]} + ${#machine_pending[@]} ))

if (( total > 0 )); then
    echo "💾 Saving $total setting(s)..."
    echo ""

    for entry in "${global_pending[@]+"${global_pending[@]}"}"; do
        _append_entry "$global_file" "$entry"
        read -r d k _ v <<< "$entry"
        echo "  ✔ [global]  $d $k = $v"
    done

    for entry in "${machine_pending[@]+"${machine_pending[@]}"}"; do
        _append_entry "$machine_file" "$entry"
        read -r d k _ v <<< "$entry"
        echo "  ✔ [machine] $d $k = $v"
    done

    echo ""
    printf "Commit the changes? [y/N]: "
    read -r commit_choice
    case "$(echo "$commit_choice" | tr '[:upper:]' '[:lower:]')" in
        y|yes)
            git -C "$DOTFILES_DIR" add -f macos/settings*.sh
            $_ignore_modified && git -C "$DOTFILES_DIR" add -f macos/ignore
            git -C "$DOTFILES_DIR" commit -m 'feat(macos): update tracked settings'
            ;;
        *)
            echo "   git -C \"\$DOTFILES_DIR\" add -f macos/settings*.sh"
            $_ignore_modified && echo "   git -C \"\$DOTFILES_DIR\" add -f macos/ignore"
            echo "   git -C \"\$DOTFILES_DIR\" commit -m 'feat(macos): update tracked settings'"
            ;;
    esac
elif $_ignore_modified; then
    echo ""
    printf "Commit ignore file changes? [y/N]: "
    read -r commit_choice
    case "$(echo "$commit_choice" | tr '[:upper:]' '[:lower:]')" in
        y|yes)
            git -C "$DOTFILES_DIR" add -f macos/ignore
            git -C "$DOTFILES_DIR" commit -m 'feat(macos): update scan ignore list'
            ;;
        *)
            echo "   git -C \"\$DOTFILES_DIR\" add -f macos/ignore"
            echo "   git -C \"\$DOTFILES_DIR\" commit -m 'feat(macos): update scan ignore list'"
            ;;
    esac
else
    echo "✅ No changes to save."
fi

# ---------------------------------------------------------------------------
# Step 6: Rotate state
# ---------------------------------------------------------------------------
mv "$state_current" "$state_previous"
