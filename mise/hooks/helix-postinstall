#!/bin/bash
# Install Helix runtime overrides (custom queries, etc.)

set -e

# Get helix installation directory
HELIX_BIN="$1"
HELIX_DIR=$(dirname "$(dirname "$HELIX_BIN")")
HELIX_RUNTIME="${HELIX_DIR}/runtime"

# Copy custom queries from config to runtime
for query_dir in markdown markdown-rustdoc rust-format-args; do
  if [[ -d "${DOTFILES_DIR}/helix/queries/${query_dir}" ]]; then
    mkdir -p "${HELIX_RUNTIME}/queries/${query_dir}"
    cp "${DOTFILES_DIR}/helix/queries/${query_dir}"/*.scm "${HELIX_RUNTIME}/queries/${query_dir}/" 2>/dev/null || true
  fi
done

echo "Helix runtime overrides installed"
