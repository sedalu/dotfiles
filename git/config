[user]
    name = Seth Lumnah
    email = seth.lumnah@boldlygo.dev
    signingkey = ~/.ssh/id_ed25519.pub
[gpg]
    format = ssh
[gpg "ssh"]
    allowedSignersFile = ~/.config/git/allowed_signers
[commit]
    gpgSign = true
[tag]
    gpgSign = true
[filter "lfs"]
    process = git-lfs filter-process
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
[init]
    defaultBranch = main
[core]
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    side-by-side = false
    dark = true
    syntax-theme = Dracula
    line-numbers = true
    hunk-header-style = syntax
    minus-style = syntax "#45213b"
    minus-emph-style = syntax "#7d2e4a"
    plus-style = syntax "#1f3a36"
    plus-emph-style = syntax "#2d5a52"
    line-numbers-minus-style = "#f38ba8"
    line-numbers-plus-style = "#a6e3a1"
    line-numbers-zero-style = "#6c7086"
[merge]
    conflictStyle = zdiff3
[diff]
    colorMoved = default
[alias]
    co = checkout
    br = branch
    st = status
    lg = log --oneline --graph --decorate
    unstage = reset HEAD --
    amend = commit --amend --no-edit
